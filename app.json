{
  "name": "seroocool",
  "services": [
    {
      "name": "web",
      "git": {
        "branch": "main",
        "repo_clone_url": "https://github.com/thenewchapter1785-tech/seroocool-fresh.git"
      },
      "build_command": "npm run build",
      "run_command": "npm run start",
      "source_dir": ".",
      "envs": [
        {
          "key": "NODE_ENV",
          "value": "production"
        }
      ],
      "http_port": 3000,
      "instance_count": 1,
      "instance_size_slug": "basic-xs"
    }
  ],
  "static_sites": [],
  "databases": [],
  "functions": []
}
